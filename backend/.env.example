# ============================================
# Database Settings
# ============================================

# Database URL (SQLite for MVP, PostgreSQL for production)
# SQLite: sqlite+aiosqlite:///./interview_assistant.db
# PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./interview_assistant.db

# Enable SQL query logging (set to true for debugging)
DATABASE_ECHO=false

# ============================================
# Authentication Settings
# ============================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT token expiration in minutes (default: 7 days = 10080 minutes)
JWT_EXPIRE_MINUTES=10080

# Google OAuth settings (optional - for "Sign in with Google")
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================
# Encryption Settings
# ============================================

# Fernet encryption key for storing user API keys securely
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================
# LLM Provider Selection
# ============================================

# Options: 'openai', 'gemini', 'gemini-live', 'adaptive', 'mock'
# 'mock' is the default and requires no API key
# 'adaptive' = Groq Whisper + Groq Llama (fastest, recommended)
LLM_PROVIDER=mock

# OpenAI API Key for Realtime API
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here

# Gemini API Key (Google AI Studio)
# Required when LLM_PROVIDER=gemini or gemini-live
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API Key (for Adaptive provider)
# Required when LLM_PROVIDER=adaptive
# Get your free API key at: https://console.groq.com/keys
# Groq provides ultra-fast Whisper transcription (~50ms) and Llama 3.3 70B
GROQ_API_KEY=your-groq-api-key-here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# Rate Limiting Settings (for Gemini free tier)
# ============================================

# Dev mode: Enable rate-limit-safe testing mode
# When true, enables rate limiting, caching, and longer audio buffers
DEV_MODE=true

# Requests per minute limit
# Gemini free tier: 15 RPM, but use 4 for safety margin
RATE_LIMIT_RPM=4

# Audio buffer duration in seconds
# Longer buffers = fewer API calls but higher latency
# 10 seconds is good for testing (2 transcription requests per minute max)
AUDIO_BUFFER_SECONDS=10

# ============================================
# Semantic Turn Detection Settings
# ============================================

# Enable semantic turn detection to avoid jittery suggestions
# When true, suggestions only generated after speaker finishes
TURN_DETECTION_ENABLED=true

# Silence duration (ms) to consider a turn complete
# Higher = fewer false triggers, but more latency
TURN_SILENCE_THRESHOLD_MS=1500

# Minimum words required for a valid turn
TURN_MIN_WORDS=3

# ============================================
# Transcript Turn Detection Settings
# ============================================

# Use frontend VAD speech timing for turn detection (Option B1)
# true = B1 (accurate, uses actual speech timing from frontend VAD)
# false = Option A (legacy, uses transcript arrival time - less accurate)
USE_SPEECH_TIMING_FOR_TURNS=true

# Silence duration (ms) to consider a new turn (for Option B1)
# This is the actual silence duration from frontend VAD
# 3000ms (3 seconds) works well for natural conversation pauses
SPEECH_SILENCE_THRESHOLD_MS=3000

# ============================================
# Legacy Settings
# ============================================

# Legacy mock mode (deprecated - use LLM_PROVIDER instead)
# Set to false when you have a real API key configured
USE_MOCK_OPENAI=true
