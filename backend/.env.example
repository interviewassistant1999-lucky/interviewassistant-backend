# LLM Provider Selection
# Options: 'openai', 'gemini', 'mock'
# 'mock' is the default and requires no API key
LLM_PROVIDER=mock

# OpenAI API Key for Realtime API
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here

# Gemini API Key (Google AI Studio)
# Required when LLM_PROVIDER=gemini
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Legacy mock mode (deprecated - use LLM_PROVIDER instead)
# Set to false when you have a real API key configured
USE_MOCK_OPENAI=true
